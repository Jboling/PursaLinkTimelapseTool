# PrusaLink (HTTP Digest) — printer base URL, no trailing slash
PRUSA_BASE_URL=http://prusa-core-one
PRUSA_USERNAME=change_me
PRUSA_PASSWORD=change_me

# RTSP URL for snapshots (go2rtc local relay recommended)
# Example: rtsp://127.0.0.1:8554/core1
RTSP_URL=rtsp://127.0.0.1:8554/core1

# Web server
# HOST=127.0.0.1 — only this machine can connect (default).
# HOST=0.0.0.0 — listen on all interfaces so you can open the UI from another device on
# the same LAN or via Tailscale (use your PC's Tailscale IP on the phone). Use Windows
# Firewall + Tailscale ACLs as needed; the app has no extra login beyond PrusaLink creds.
HOST=127.0.0.1
PORT=8765

# FFmpeg is required for snapshots. If you see WinError 2 / file not found, set the
# full path to ffmpeg.exe (Windows often does not inherit PATH the same as a shell).
# FFMPEG_PATH=C:\ffmpeg\bin\ffmpeg.exe

# Where runtime UI settings are stored (interval, folder, etc.)
USER_SETTINGS_PATH=data/user_settings.json
